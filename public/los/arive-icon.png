  jQuery("#btn_schedule_demo").click(async function(){
         if(jQuery("#wf-form-Schedule-Demo-Form")[0].checkValidity()) {
         const name = jQuery("#name-2").val();
         const email = jQuery("#email-2").val();
         const phone = jQuery("#phone-2").val();
         const company = jQuery("#company-2").val();
         const column_values = {
             email: {
               email: email,
               text: email
             },
             phone: phone,
             text0: company
        }

        const values = JSON.stringify(column_values).replace(/(\\n)/g," ").replace(/\\([\s\S])|(")/g,"\\$1$2");
        const postQuery = `mutation { create_item (board_id: 1700381340, group_id: "topics", item_name: "${name}", column_values: "${values}") { id, name }}`
        //alert(postQuery);
        const response = await fetch('https://api.monday.com/v2',
                                 {
                                 method: 'post',
                                 headers: {
                                 'Content-Type': 'application/json',
                                 Authorization: 'eyJhbGciOiJIUzI1NiJ9.eyJ0aWQiOjEyNTU5NDAxOCwidWlkIjoyNDA3ODc4NSwiaWFkIjoiMjAyMS0wOS0yMlQwNTo1ODo1MS4wOTlaIiwicGVyIjoibWU6d3JpdGUiLCJhY3RpZCI6NTQxNjgwNywicmduIjoidXNlMSJ9.xgY5UThjGdEUdd67ykWus1KaTAwas0pqThr18tHFs7o',
                                 },
                                  body: JSON.stringify({
                                    query : postQuery
                                  })
                                }
        );

        const json = await response.json();

        if(json.errors) {
          // alert(“Error: ” + JSON.stringify(json.errors, 2));
        } else {
          // jQuery(‘.register-modal’).removeClass(‘show’);
          // jQuery(‘.register-thankyou-modal’).addClass(‘show’);
        }

    }
});
}, 1000);

